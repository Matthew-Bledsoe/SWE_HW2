<!DOCTYPE html>
<html>
<head>
  <title><%= recipe.name %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<div class="container">
    <a href="/" class="home-button">Home</a>
  <h1><%= recipe.name %></h1>
  <p><%= recipe.description %></p>
  <p>Prep Time: <%= recipe.prep_time_minutes %> minutes</p>

  <h2>Ingredients</h2>
  <ul class="ingredients">
    <% ingredients.forEach(item => { %>
      <li title="<%= item.info || 'No additional info' %>">
        <%= item.quantity %> - <%= item.ingredient_name %>
      </li>
    <% }) %>
  </ul>

  <h2>Steps</h2>
  <ol>
    <% steps.forEach(step => { %>
      <li><%= step.instruction %></li>
    <% }) %>
  </ol>

  <a href="/recipes" class="back-link">Back to Listings</a>
</div>
</body>
</html>